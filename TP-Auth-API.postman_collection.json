{
  "info": {
    "name": "TP Auth API - NodeJS/Express",
    "description": "Collection complète pour tester l'API d'authentification",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🏠 Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/"
      }
    },
    {
      "name": "📧 Auth - Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"Password123!\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/register"
      }
    },
    {
      "name": "📧 Auth - Verify Email",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/verificationMail/verify?token={{verificationToken}}"
      }
    },
    {
      "name": "📧 Auth - Resend Verification",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@example.com\"\n}"
        },
        "url": "{{baseUrl}}/api/verificationMail/resend"
      }
    },
    {
      "name": "🔑 Auth - Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"Password123!\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      }
    },
    {
      "name": "🔑 Auth - Login (2FA)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"tempToken\": \"{{tempToken}}\",\n  \"twoFactorCode\": \"123456\"\n}"
        },
        "url": "{{baseUrl}}/api/2fa/verify-login"
      }
    },
    {
      "name": "🔄 Auth - Refresh Token",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/refresh"
      }
    },
    {
      "name": "🚪 Auth - Logout",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/logout"
      }
    },
    {
      "name": "🔒 Auth - Forgot Password",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@example.com\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/forgot-password"
      }
    },
    {
      "name": "🔒 Auth - Reset Password",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"newPassword\": \"NewPassword123!\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/reset-password"
      }
    },
    {
      "name": "🔒 Auth - Change Password",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"currentPassword\": \"Password123!\",\n  \"newPassword\": \"NewPassword123!\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/change-password"
      }
    },
    {
      "name": "🔐 2FA - Setup",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{baseUrl}}/api/2fa/setup"
      }
    },
    {
      "name": "🔐 2FA - Enable",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"123456\"\n}"
        },
        "url": "{{baseUrl}}/api/2fa/enable"
      }
    },
    {
      "name": "🔐 2FA - Disable",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"123456\"\n}"
        },
        "url": "{{baseUrl}}/api/2fa/disable"
      }
    },
    {
      "name": "👤 Users - Get All",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/api/users"
      }
    },
    {
      "name": "👤 Users - Get Me",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/api/users/me"
      }
    },
    {
      "name": "👤 Users - Update Me",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Smith\"\n}"
        },
        "url": "{{baseUrl}}/api/users/me"
      }
    },
    {
      "name": "👤 Users - Delete Me",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/api/users/me"
      }
    },
    {
      "name": "🖥️ Sessions - List",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/api/sessions"
      }
    },
    {
      "name": "🖥️ Sessions - Revoke One",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/api/sessions/{{sessionId}}"
      }
    },
    {
      "name": "🖥️ Sessions - Revoke Others",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"currentRefreshToken\": \"{{refreshToken}}\"\n}"
        },
        "url": "{{baseUrl}}/api/sessions/others"
      }
    },
    {
      "name": "🌐 OAuth - Google",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/oauth/google"
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "tempToken", "value": "" },
    { "key": "verificationToken", "value": "" },
    { "key": "resetToken", "value": "" },
    { "key": "sessionId", "value": "" }
  ]
}